[sub_resource type="GDScript" id="GDScript_s2f8l"]
script/source = "extends CheckBox

func _ready() -> void:
	set_pressed(Ui.get_data().always_on_top)
	_on_button_up()

func _on_button_up() -> void:
	DisplayServer.window_set_flag(DisplayServer.WINDOW_FLAG_ALWAYS_ON_TOP, is_pressed() )
"

